{
  "$schema": "https://renovatebot.com",
  "extends": [
    "config:recommended"
  ],
  "automerge": true,
  "platformAutomerge": true,
  "rebaseWhen": "behind-base-branch",
  "packageRules": [
    {
      "groupName": "all angular dependencies",
      "groupSlug": "angular-group",
      "matchPackageNames": [
        "/^@angular//"
      ]
    },
    {
      "matchDepNames": [
        "^org\\.springframework(\\.boot|\\.data)?:"
      ],
      "groupName": "all spring dependencies",
      "groupSlug": "all-spring-dependencies",
      "registryUrls": [
        "https://apache.org"
      ]
    }
  ]
}
